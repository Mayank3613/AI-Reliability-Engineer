

# Use Google Cloud Secret Manager for production, or env vars for local dev
USE_SECRET_MANAGER=false

# Deployment environment (development, staging, production)
ENVIRONMENT=development


# ═══════════════════════════════════════════════════════════════════════════════
# ☁️  GOOGLE CLOUD PLATFORM (GCP)
# ═══════════════════════════════════════════════════════════════════════════════

# Your GCP project ID
# Get from: https://console.cloud.google.com/
GCP_PROJECT_ID=aire-dev-498715

# GCP region for services
# Options: us-central1, us-east1, europe-west1, asia-northeast1, etc.
GCP_REGION=us-central1

# Path to service account JSON key file
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Leave empty in Cloud Run (uses Workload Identity)
GOOGLE_APPLICATION_CREDENTIALS="C:\Users\prana\Downloads\aire-dev-498715-6d1ad22c8c17.json"

# Vertex AI location
VERTEX_AI_LOCATION=us-central1


# ═══════════════════════════════════════════════════════════════════════════════
# 🤖 GOOGLE GEMINI API (LLM Models)
# ═══════════════════════════════════════════════════════════════════════════════

# Gemini API key (for local dev; in production, use Application Default Credentials)
# Get from: https://aistudio.google.com/apikey
# In Cloud Run: leave empty (uses GCP service account)
GEMINI_API_KEY=AQ.Ab8RN6LMvNdtUcYNNRbn9HEuPhtn7aCYVvYXK6C-qL6Z9PcyHw

# Model selections
GEMINI_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-1.5-pro


# ═══════════════════════════════════════════════════════════════════════════════
# 📡 DYNATRACE (Observability & Monitoring)
# ═══════════════════════════════════════════════════════════════════════════════

# Your Dynatrace environment ID (without domain)
# Get from: https://hub.cloud.dynatrace.com/ → Select environment
# Example: abc12345 (from abc12345.live.dynatrace.com)
DYNATRACE_ENVIRONMENT_ID=loh23233

# Dynatrace API token (with metrics.read, traces.read, logs.read permissions)
# Get from: https://docs.dynatrace.com/docs/platform/platform-services/user-management/api-tokens
DYNATRACE_API_KEY=dt0c01.XXXXXXXXXXXXXXXXXXXXXXXX

# OTLP endpoint for metric/trace export
# Constructed as: https://{DYNATRACE_ENVIRONMENT_ID}.live.dynatrace.com/api/v2/otlp
DT_OTLP_ENDPOINT=https://abc12345.live.dynatrace.com/api/v2/otlp

# OTLP API token (usually same as DYNATRACE_API_KEY)
DT_API_TOKEN=dt0c01.XXXXXXXXXXXXXXXXXXXXXXXX

# Email for alerts
ALERT_EMAIL=your-email@example.com


# ═══════════════════════════════════════════════════════════════════════════════
# 🔀 BINDPLANE (Telemetry Router)
# ═══════════════════════════════════════════════════════════════════════════════

# BindPlane server endpoint
# Get from your BindPlane deployment (default port 3001)
BINDPLANE_ENDPOINT=https://your-bindplane-server:3001

# BindPlane API authentication key
BINDPLANE_API_KEY=your-bindplane-api-key


# ═══════════════════════════════════════════════════════════════════════════════
# 🧠 AGENT SEARCH & KNOWLEDGE BASE (Discovery Engine)
# ═══════════════════════════════════════════════════════════════════════════════

# Datastore location
AGENT_SEARCH_LOCATION=global

# Datastore ID for document storage
# Create in: https://console.cloud.google.com/vertex-ai/search
DATASTORE_ID=aire-knowledge-store

# Optional: Search engine ID
SEARCH_ENGINE_ID=aire-search-engine


# ═══════════════════════════════════════════════════════════════════════════════
# 📊 EMBEDDINGS & VECTOR SEARCH
# ═══════════════════════════════════════════════════════════════════════════════

# Model for text embeddings
EMBEDDING_MODEL=text-embedding-004


# ═══════════════════════════════════════════════════════════════════════════════
# 🔍 OPENTELEMETRY & TRACING
# ═══════════════════════════════════════════════════════════════════════════════

# Service name for telemetry (appears in traces/metrics)
OTEL_SERVICE_NAME=aire-backend

# OTLP collector endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=https://abc12345.live.dynatrace.com/api/v2/otlp

# OTLP headers for authentication (e.g., Dynatrace API token)
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Api-Token dt0c01.XXXXXXXXXXXXXXXXXXXXXXXX


# ═══════════════════════════════════════════════════════════════════════════════
# 🌐 WEB & API
# ═══════════════════════════════════════════════════════════════════════════════

# API server port
PORT=8080

# API base URL (for Cloud Run or custom domain)
API_BASE_URL=http://localhost:8080

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080


# ═══════════════════════════════════════════════════════════════════════════════
# 💾 DATABASE (Optional - if using persistence)
# ═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL or compatible database URL
# Example: postgresql://user:password@localhost:5432/aire_db
DATABASE_URL=

# MongoDB URL (if using MongoDB for document storage)
# Example: mongodb+srv://user:password@cluster.mongodb.net/aire
MONGODB_URL=

# Redis URL (if using for caching)
# Example: redis://localhost:6379/0
REDIS_URL=


# ═══════════════════════════════════════════════════════════════════════════════
# 🔑 ADDITIONAL SECRETS (if needed)
# ═══════════════════════════════════════════════════════════════════════════════

# JWT secret for token signing
SECRET_KEY=your-secret-key-change-in-production

# API key for external integrations
API_KEY=

# Additional custom secrets
CUSTOM_SECRET=


# ═══════════════════════════════════════════════════════════════════════════════
# 📝 LOGGING & DEBUG
# ═══════════════════════════════════════════════════════════════════════════════

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable debug mode (more verbose logging)
DEBUG=false
