# AIRE — Environment Variables
# Copy this to .env and fill in values for local development.
# In production (Cloud Run), all secrets come from Secret Manager.
# NEVER commit a filled .env file to version control.

# ── Google Cloud ──────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
VERTEX_AI_LOCATION=us-central1

# ── Dynatrace ─────────────────────────────────────────────────────────────────
DYNATRACE_ENVIRONMENT_ID=abc12345          # e.g. abc12345.live.dynatrace.com
DYNATRACE_API_KEY=dt0c01.XXXXXXXXXX...    # Dynatrace API token

# ── Bindplane ─────────────────────────────────────────────────────────────────
BINDPLANE_ENDPOINT=https://your-bindplane-server:3001
BINDPLANE_API_KEY=your-bindplane-api-key

# ── Agent Search / RAG ────────────────────────────────────────────────────────
AGENT_SEARCH_LOCATION=global
DATASTORE_ID=aire-knowledge-store
SEARCH_ENGINE_ID=aire-search-engine

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-004

# ── Gemini ────────────────────────────────────────────────────────────────────
# In Cloud Run, use Workload Identity (ADC). Only needed for local dev.
GEMINI_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-1.5-pro

# ── Cloud Run ─────────────────────────────────────────────────────────────────
PORT=8080

# ── Secret Manager ────────────────────────────────────────────────────────────
# Set to "false" for local dev to use env vars above directly.
USE_SECRET_MANAGER=false

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=aire-backend
OTEL_EXPORTER_OTLP_ENDPOINT=https://your-dynatrace-env.live.dynatrace.com/api/v2/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Api-Token your-token-here
